{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@assets/*": ["../assets/*"],
      "@components/*": ["components/*"],
      "@constants/*": ["constants/*"],
      "@helpers/*": ["helpers/*"],
      "@hooks/*": ["hooks/*"],
      "@i18n/*": ["i18n/*"],
      "@routes/*": ["routes/*"],
      "@store/*": ["store/*"],
      "@screens/*": ["screens/*"],
      "@theme/*": ["theme/*"],
      "@utils/*": ["utils/*"]
    }
  },
  "include": ["src/**/*", "index.js", "App.tsx", "**/*.d.ts"],
  "exclude": [
    "__tests__",
    ".bundle",
    "android",
    "ios",
    "node_modules",
    "vendor",
    "babel.config.js",
    "jest.config.js",
    "metro.config.js",
    "coverage",
    "tsconfig.json"
  ]
}
